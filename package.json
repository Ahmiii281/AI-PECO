{
  "name": "aipeco-workspace",
  "version": "1.0.0",
  "description": "AI-Powered Energy Consumption Optimizer",
  "scripts": {
    "build": "cd frontend && npm install && npm run build",
    "dev": "npm i -g concurrently && concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && python main.py",
    "install:all": "cd frontend && npm install && cd ../backend && pip install -r requirements.txt",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down"
  },
  "author": "AI-PECO Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.15.2",
    "marked": "^18.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  }
}
