# FastAPI Configuration
APP_NAME=AI-PECO
APP_VERSION=1.0.0
DEBUG=False

# MongoDB
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=aipeco_db

# JWT Configuration
SECRET_KEY=your-secret-key-keep-it-safe-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://aipeco-frontend.vercel.app

# ESP32 Configuration
ESP32_POLLING_INTERVAL=5
DATA_RETENTION_DAYS=30
DEVICE_API_KEY=change-me-for-production

# Energy Settings
ENERGY_PRICE_PER_UNIT=50
ANOMALY_THRESHOLD_SIGMA=2.0

# Features
ENABLE_AI_PREDICTIONS=True
ENABLE_AUTO_ALERTS=True
